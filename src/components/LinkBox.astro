---
import { BASE_DIR, IMG_PATH } from '/src/consts';

interface LinkItem {
	text: string;
	href: string;
}

interface Props {
	imageSrc?: string; // 画像のパス
	title?: string; // タイトル
	links?: LinkItem[]; // リンクのリスト
	addClass?: string; // 追加クラス
}

const { imageSrc = '', title = '', links = [], addClass = '' } = Astro.props;
---
<div class={`linkBox ${addClass}`}>
    <p class="linkBox-title">{title}</p>
    <div class="linkBox-content">
        <figure class="linkBox-image">
            <img src={imageSrc} width="150" height="120" alt="">
        </figure>
        <div class="linkBox-text">
            <ul class="linkBox-list">
            {links.map((link) => (
                <li class="linkBox-list-item"><a href={link.href}>{link.text}</a></li>
            ))}
            </ul>
        </div>
    </div>
</div>

<style lang="scss">
    .linkBox {
        background-color: #f6f4f8;
        border-radius: 6px;
        padding: 10px 20px;
        color: #2e3174;

        @media print {
            break-inside: avoid;
            page-break-inside: avoid;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            color-adjust: exact;
        }

        &-title {
            font-weight: 700;
            text-align: center;
        }

        &-content {
            display: flex;
            column-gap: 15px;
            margin-top: 10px;
        }

        &-image {
            margin-block: auto;
            flex: 0 0 auto;

            img {
                border-radius: 6px;
            }
        }

        &-text {
            flex-grow: 1;
            line-height: 1.5;
        }


        &-list {

            &-item {
                font-size: 1.4rem;
                position: relative;
                border-bottom: 1px solid rgba($color: #2e3174, $alpha: 0.1);

                &:last-of-type {
                    border-bottom: none;
                }

                &::after {
                    position: absolute;
                    content: "";
                    top: 12px;
                    right: 0;
                    margin: auto;
                    width: 1em;
                    height: 1em;
                    font-size: 6px;
                    border-top-style: solid;
                    border-left-style: solid;
                    border-width: 1px;
                    border-color: #2E3174;
                    rotate: 135deg;
                    pointer-events: none;
                }

                a {
                    display: block;
                    padding: 5px 30px 5px 0;
                }
            }
        }
    }
</style>
