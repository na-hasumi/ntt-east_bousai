---
/********************************************************************
 * トップへ戻るボタン
 **********************************************************************/
interface Props {
	src?: string;
}
const { src } = Astro.props as Props;
---

<a class="gotop" href="#" aria-label="ページ上部へ戻る">
	{src ? <img class="gotop_img" src={src} alt="" width="60" height="60" decoding="async" /> : null}
</a>

<style lang="scss">
.gotop {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 77px;
    height: 77px;
    background-color: transparent;
    transition: 0.2s;
    border-radius: 100vmax;
    text-decoration: none;

    @include g.mq('md') {
        width: 80px;
        height: 80px;
    }

    &:hover {
        opacity: 0.85;
    }

    &_img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    &:not(:has(.gotop_img)) {
        background-color: g.color('key_light');
        &::before {
            @include g.arrow(top, 7px, 1px, g.color('white'));
            content: '';
            position: absolute;
            inset: 6px 0 0;
            margin: auto;
        }
    }
}
</style>
