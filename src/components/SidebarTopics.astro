---
import { NAV_LIST } from '../consts';
import topicsData from '@pages/_topics.json';

const years = ((topicsData as any)?.years ?? []).slice(1);
const isDev = import.meta.env.DEV;

// dev: ルーティングは拡張子無し（/topics, /topics2023）
// build: 静的出力は .html 付き（/topics.html, /topics2023.html）
const hrefLatest = isDev ? '/topics' : '/topics.html';
const hrefYear = (year: number | string) => (isDev ? `/topics${year}` : `/topics${year}.html`);

interface Props {
  parent?: string; // 親カテゴリー
  parent2?: string; // 子カテゴリー
  parent3?: string; // 孫カテゴリー
  addClass?: string; // 追加クラス
}

const { parent = '', parent2 = '', parent3 = '', addClass = '' } = Astro.props;

// トピックス一覧のメニューを取得（存在しない場合もあるので安全に）
const Nav = NAV_LIST.find((nav) => nav.name === 'トピックス一覧') as any;
---

<div class="sidebar_unit">
  <h2 class={`sidebar_title ${parent === 'トピックス一覧' ? 'is_active' : ''}`}>
    <a href={hrefLatest}>トピックス一覧（最新）</a>
  </h2>
  <ul class="sidebar_list">
    {years.map((y: any) => (
      <li class="sidebar_item">
        <a
          href={hrefYear(y.year)}
          class={`sidebar_item_name js_accordion_trigger ${String(parent2) === String(y.year) ? 'is_active' : ''}`}
          data-target={y.year}
        >
          {y.year}年度
        </a>
      </li>
    ))}
  </ul>
</div>

<style lang="scss">
@use "@styles/sidebar";
</style>

