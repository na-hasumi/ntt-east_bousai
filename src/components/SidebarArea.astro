---
import SidebarService from '@components/SidebarService.astro';
import SidebarAnalyzer from '@components/SidebarAnalyzer.astro';
import SidebarAnalysis from '@components/SidebarAnalysis.astro';
import SidebarProfile from '@components/SidebarProfile.astro';
import SidebarPublications from '@components/SidebarPublications.astro';
import SidebarTopics from '@components/SidebarTopics.astro';
import SidebarContact from '@components/SidebarContact.astro';

interface Props {
	parent?: string; // 親カテゴリー
	parent2?: string; // 子カテゴリー
	parent3?: string; // 孫カテゴリー
	addClass?: string; // 追加クラス
}

const { parent = '', parent2 = '', parent3 = '', addClass = '' } = Astro.props;

// Sidebar出し分けはこのファイルで管理する（src/consts.js では管理しない）
const ComponentMap: Record<string, any> = {
  SidebarService,
  SidebarAnalyzer,
  SidebarAnalysis,
  SidebarProfile,
  SidebarPublications,
  SidebarTopics,
  SidebarContact,
};

type SidebarKey = keyof typeof ComponentMap;

const DEFAULT_ORDER: SidebarKey[] = [
  'SidebarService',
  'SidebarAnalyzer',
  'SidebarAnalysis',
  'SidebarPublications',
  'SidebarTopics',
  'SidebarProfile',
  'SidebarContact',
];

// ルール：該当ページでは primary + include のみを表示する（exclude は使わない）
// include は「primary に追加で表示したいものだけ」を書く（少数で済む想定）
const RULES: Record<string, { primary: SidebarKey; include?: SidebarKey[] }> = {
  '分析対象': { primary: 'SidebarService', include: ['SidebarAnalyzer'] },
  '分析機能（装置）': { primary: 'SidebarAnalyzer', include: ['SidebarService'] },
  '分析事例': { primary: 'SidebarAnalysis' },
  '外部発表': { primary: 'SidebarPublications' },
  'トピックス一覧': { primary: 'SidebarTopics' },
  '会社案内': { primary: 'SidebarProfile' },
  'お問合せ・ご依頼': { primary: 'SidebarContact' },
};

const rule = RULES[parent] ?? null;

let order: SidebarKey[] = [...DEFAULT_ORDER];
if (rule?.primary) {
  // primary を先頭に固定し、include だけ追加で表示（重複は除外）
  const include = (rule.include ?? []).filter((k) => k !== rule.primary);
  order = [rule.primary, ...include];
}

const renderList = order.map((key) => ({
  key,
  Component: ComponentMap[key],
}));
---

<div class="sidebarArea">
	<div class="sidebar">
        {renderList.map((item, index) => {
          const props = index === 0 ? { parent, parent2, parent3 } : {};
          const Cmp = item.Component;
          return Cmp ? <Cmp {...props} /> : null;
        })}
	</div>
</div>
<style lang="scss">
	.sidebarArea{
		margin-top: 70px;
		flex: 0 0 auto;

		@media print {
			display: none;
		}
	}

	.sidebar{
		display: flex;
		flex-direction: column;
		gap: 35px;
		width: min(g.get_vw(327, 1200), 327px);
	}
</style>
