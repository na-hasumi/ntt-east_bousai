---
import { IMG_PATH } from '/src/consts';
import Inner from '@components/Inner.astro';

interface Props {
	title?: string; // タイトル
	subTitle?: string; // サブタイトル
	src?: string; // 画像のパス
	addClass?: string; // 追加クラス
}

const { title = '', subTitle = '', src = '', addClass = '' } = Astro.props;
---
<div class="mv">
    <figure class="mv_bg">
        <img src={IMG_PATH + src} width="1440" height="371" alt="mv">
    </figure>
    <Inner>
        <div class="mv_titlebox">
            <p class="mv_subtitle">{subTitle}</p>
            <p class="mv_title">{title}</p>
        </div>
    </Inner>
</div>

<style lang="scss">
    .mv{
    position: relative;

    @media print {
        display: none;
    }

    &_bg{
        img{
            width: 100%;
            height: 371px;
            object-fit: cover;
        }
    }

    :global(.inner){
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    &_subtitle{
        font-size: 1.8rem;
        color: g.color('key_light');
        margin-bottom: 10px;
    }

    &_title{
        font-size: 5.5rem;
        font-weight: 300;
        line-height: 1.2;
    }
}
</style>
