---
import Inner from '@components/Inner.astro';

interface Props {
	title: string; // タイトル（HTMLタグを含む可能性あり）
}

const { title } = Astro.props;
---

<div class="title_wrap">
    <Inner>
        <h1 class="title">
            <Fragment set:html={title} />
        </h1>
    </Inner>
</div>

<style lang="scss" is:global>
.title_wrap{
    overflow: clip;
}
.title_wrap .title{
    position: relative;
    width: min(g.get_vw(820,1200), 820px);
    margin-top: -30px;
    margin-left: auto;
    background: #000;
    padding: 8px 30px;
    color: #fff;
    font-size: 2.6rem;
    white-space: pre-line;
    line-height: 1.4;

    &::before{
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        left: 15px;
        margin: auto;
        width: 3px;
        height: 60%;
        background: g.color('key_light');
    }

    &::after{
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        left: 0;
        transform: translateX(99%);
        margin: auto;
        width: 100%;
        height: 100%;
        background: #000;
    }
}

@media print {
	.title_wrap {
        margin-bottom: 50px;
	}

	.title_wrap .title {
		width: 100%;
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
        color-adjust: exact !important;

		&::before,
		&::after {
			-webkit-print-color-adjust: exact !important;
			print-color-adjust: exact !important;
			color-adjust: exact !important;
		}
	}
}
</style>
