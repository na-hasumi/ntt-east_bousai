---
import { NAV_LIST } from '../consts';

interface Props {
	parent?: string; // 親カテゴリー
	parent2?: string; // 子カテゴリー
	parent3?: string; // 孫カテゴリー
	addClass?: string; // 追加クラス
}

const { parent = '', parent2 = '', parent3 = '', addClass = '' } = Astro.props;

// 分析機能（装置）のメニューを取得
const NavService = NAV_LIST.find(nav => nav.name === '分析対象') as any;
const NavAnalyzer = NAV_LIST.find(nav => nav.name === '分析機能（装置）') as any;
---
<div class="sidebar_unit">
	<h3 class={`sidebar_analysisTitle ${parent === NavService?.name ? 'is_active' : ''}`}><a href={NavService?.analysisLink}>分析対象別</a></h3>
	<ul class="sidebar_list">
		{NavService?.children?.filter((category: any) => category.analysisLink).map((category: any) => {
			// リンクからファイル名(slug)を抽出してdata-targetに使用
			const targetSlug = category.analysisLink ? category.analysisLink.split('/').pop().replace(/\.html?$/, '') : '';
			const isCategoryActive = parent2 === category.name;
			
			return (
				<li class="sidebar_item">
					<a href={category.analysisLink} class={`sidebar_item_name js_accordion_trigger ${isCategoryActive ? 'is_active' : ''}`} data-target={targetSlug}>{category.name}</a>
				</li>
			);
		})}
	</ul>
</div>
<div class="sidebar_unit">
	<h3 class={`sidebar_analysisTitle ${parent === NavAnalyzer?.name ? 'is_active' : ''}`}><a href={NavAnalyzer?.analysisLink}>分析機能（装置）別</a></h3>
	<ul class="sidebar_list">
		{NavAnalyzer?.children?.filter((category: any) => category.analysisLink).map((category: any) => {
			// リンクからファイル名(slug)を抽出してdata-targetに使用
			const targetSlug = category.analysisLink ? category.analysisLink.split('/').pop().replace(/\.html?$/, '') : '';
			const isCategoryActive = parent2 === category.name || parent === category.name;
			
			return (
				<li class="sidebar_item">
					<a href={category.analysisLink} class={`sidebar_item_name js_accordion_trigger ${isCategoryActive ? 'is_active' : ''}`} data-target={targetSlug}>{category.name}</a>
				</li>
			);
		})}
	</ul>
</div>
<style lang="scss">
@use "@styles/sidebar";
</style>
