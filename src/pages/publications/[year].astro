---
/********************************************************************
 * 	外部発表（年度別）
 *  - /publications/2023.html のように生成
 *  - 最新年度(years[0])は index.html のみに出し、このページは生成しない
 **********************************************************************/
import { IMG_PATH } from '/src/consts';
import Layout from '@layouts/Layout.astro';
import Inner from '@components/Inner.astro';
import MvLower from '@components/MvLower.astro';
import TitleH1 from '@components/TitleH1.astro';
import SidebarArea from '@components/SidebarArea.astro';
import publicationsData from '@pages/publications/_publications.json';

const years = (publicationsData as any)?.years ?? [];
const latestYear = years?.[0]?.year;

export async function getStaticPaths() {
  const list = (publicationsData as any)?.years ?? [];
  const latest = list?.[0]?.year;

  return list
    .filter((y: any) => y?.year && y.year !== latest)
    .map((y: any) => ({
      params: { year: String(y.year) },
      props: { yearData: y, allYears: list },
    }));
}

function nl2brLines(s: string) {
  return String(s ?? '').split('\n');
}

type LinkItem = { href: string; text: string };

type TextSeg =
  | { type: 'text'; value: string }
  | { type: 'link'; href: string; text: string; external: boolean };

function isExternalHref(href: string) {
  return /^https?:\/\//i.test(String(href ?? ''));
}

function buildLinkedSegments(text: string, links?: LinkItem[]): TextSeg[] {
  let segs: TextSeg[] = [{ type: 'text', value: String(text ?? '') }];
  if (!Array.isArray(links) || links.length === 0) return segs;

  for (const l of links) {
    const href = typeof l?.href === 'string' ? l.href : '';
    const t = typeof l?.text === 'string' ? l.text : '';
    if (!href || !t) continue;

    let replaced = false;
    const next: TextSeg[] = [];

    for (const s of segs) {
      if (s.type !== 'text' || replaced) {
        next.push(s);
        continue;
      }

      const idx = s.value.indexOf(t);
      if (idx === -1) {
        next.push(s);
        continue;
      }

      replaced = true;
      const before = s.value.slice(0, idx);
      const after = s.value.slice(idx + t.length);
      if (before) next.push({ type: 'text', value: before });
      next.push({ type: 'link', href, text: t, external: isExternalHref(href) });
      if (after) next.push({ type: 'text', value: after });
    }

    segs = next;
  }

  return segs;
}

function getDtParts(dtItem: any): { text: string; links?: LinkItem[] } {
  if (typeof dtItem === 'string') return { text: dtItem };
  const text = typeof dtItem?.text === 'string' ? dtItem.text : String(dtItem?.text ?? '');
  const links = Array.isArray(dtItem?.links) ? (dtItem.links as LinkItem[]) : undefined;
  return { text, links };
}

function getDdParts(ddItem: any): { text: string; className?: string; links?: LinkItem[] } {
  if (typeof ddItem === 'string') return { text: ddItem };
  const text = typeof ddItem?.text === 'string' ? ddItem.text : String(ddItem?.text ?? '');
  const className = typeof ddItem?.className === 'string' && ddItem.className.trim() ? ddItem.className : undefined;
  const links = Array.isArray(ddItem?.links) ? (ddItem.links as LinkItem[]) : undefined;
  return { text, className, links };
}

const paramYear = Number(Astro.params.year);
const yearData =
  (Astro.props as any)?.yearData ??
  years.find((y: any) => Number(y?.year) === paramYear);

// dev/SSR で最新年度にアクセスされた場合は index に寄せる
if (paramYear && latestYear && paramYear === Number(latestYear)) {
  return Astro.redirect('/publications/index.html');
}

if (!yearData) {
  return Astro.redirect('/404');
}

const meta = {
  title: `外部発表（${yearData.year}年度）`,
  description: '外部発表',
};

const allYears = (Astro.props as any)?.allYears ?? years;
const olderYears = (allYears ?? []).filter((y: any) => y?.year && y.year !== latestYear);
---

<Layout pageId="documents" title={meta.title} description={meta.description}>
  <MvLower title="外部発表" subTitle="Publications" src="mv/mv-publications.webp" />
  <TitleH1 title={`外部発表（${yearData.year}年度）`} />

  <div class="main">
    <Inner>
      <SidebarArea parent="外部発表" parent2={yearData.year}/>
      <div id="content">
        <div class="print-btn">
          <a href="#" onclick="window.print();return false;">
            <img src={IMG_PATH + "common/btn_print.svg"} alt="このページを印刷する" width="189" height="33" />
          </a>
        </div>

        {yearData.sections?.map((section: any) => (
          <>
            <h2 class="h2-std">{section.title}</h2>
            <dl class="dl-publications">
              {section.entries?.map((e: any) => (
                <>
                  {(() => {
                    const { text: dtText, links } = getDtParts(e.dt);
                    return (
                      <dt>
                        {nl2brLines(dtText).map((line, idx) => (
                          <>
                            {idx > 0 && <br />}
                            {buildLinkedSegments(line, links).map((seg) =>
                              seg.type === 'text' ? (
                                seg.value
                              ) : (
                                <a
                                  href={seg.href}
                                  target={seg.external ? '_blank' : undefined}
                                  rel={seg.external ? 'noopener noreferrer' : undefined}
                                >
                                  {seg.text}
                                </a>
                              )
                            )}
                          </>
                        ))}
                      </dt>
                    );
                  })()}
                  {Array.isArray(e.dd) &&
                    e.dd.map((ddItem: any) => {
                      const { text: ddText, className, links } = getDdParts(ddItem);
                      return (
                      <dd class={className}>
                        {nl2brLines(ddText).map((line, idx) => (
                          <>
                            {idx > 0 && <br />}
                            {buildLinkedSegments(line, links).map((seg) =>
                              seg.type === 'text' ? (
                                seg.value
                              ) : (
                                <a
                                  href={seg.href}
                                  target={seg.external ? '_blank' : undefined}
                                  rel={seg.external ? 'noopener noreferrer' : undefined}
                                >
                                  {seg.text}
                                </a>
                              )
                            )}
                          </>
                        ))}
                      </dd>
                      );
                    })}
                </>
              ))}
            </dl>
          </>
        ))}
      </div>
    </Inner>
  </div>
</Layout>

<style lang="scss">
  @use "@styles/lower.scss";
  @import "@styles/documents/publications.css";
  #content{
    width: 100%;
  }
</style>

