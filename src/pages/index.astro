---
/********************************************************************
 * 	TOP
 **********************************************************************/
 import { BASE_DIR, IMG_PATH } from '../consts';
import Layout from '@layouts/Layout.astro';
import MvSlider from '@components/MvSlider.astro';
import Inner from '@components/Inner.astro';
const meta = {
	title: '',
}

---

<Layout pageId="frontpage" title={meta.title}>
	<MvSlider />

	<div class="about">
		<video class="about_video about_video_pc" src={IMG_PATH + 'common/about_pc.mp4'} autoplay loop muted playsinline></video>
		<video class="about_video about_video_sp" src={IMG_PATH + 'common/about_sp.mp4'} autoplay loop muted playsinline></video>
		<Inner addClass="about_inner">
			<div class="about_content">
				<h2 class="about_title">ABOUT US</h2>
				<p class="about_subtitle">私たちについて</p>
				<p class="about_text">伝える・備える・行動する・つなぐの<br class="hp_md_none">循環で<br class="hp_sm_none">災害と共存し、<br class="hp_md_none">成長し続けられる<br class="hp_sm_none">「フェーズフリー」<br class="hp_md_none">な地域社会の実現。</p>
				<a href="#" class="about_btn">
					READ MORE <img src={IMG_PATH + 'common/arrow.svg'} alt="READ MORE" width="8" height="5" loading="lazy">
				</a>
			</div>
		</Inner>
	</div>

	<div class="phase-free">
		<Inner>
			<div class="phase-free_header">
				<h2 class="phase-free_title">フェーズフリー 4つの行動</h2>
			</div>
			
			<div class="phase-free_actions">
				<a href="#" class="phase-free_action phase-free_action--communicate">
					<div class="phase-free_action_inner">
						<span class="phase-free_action_main">伝える</span>
						<span class="phase-free_action_sub">イベント・<br>学会発表</span>
					</div>
				</a>
				<a href="#" class="phase-free_action phase-free_action--prepare">
					<div class="phase-free_action_inner">
						<span class="phase-free_action_main">備える</span>
						<span class="phase-free_action_sub">準備・対策</span>
					</div>
				</a>
				<a href="#" class="phase-free_action phase-free_action--act">
					<div class="phase-free_action_inner">
						<span class="phase-free_action_main">行動する</span>
						<span class="phase-free_action_sub">避難</span>
					</div>
				</a>
				<a href="#" class="phase-free_action phase-free_action--connect">
					<div class="phase-free_action_inner">
						<span class="phase-free_action_main">つなぐ</span>
						<span class="phase-free_action_sub">再生・復興・<br>コミュニティ</span>
					</div>
				</a>
			</div>

			<div class="phase-free_articles">
				<article class="phase-free_article">
					<a href="#" class="phase-free_article_link">
						<figure class="phase-free_article_fig">
							<img src={IMG_PATH + 'top/dummy.webp'} alt="" loading="lazy">
						</figure>
						<div class="phase-free_article_content">
							<div class="phase-free_article_meta">
								<span class="phase-free_article_cat" data-type="communicate">伝える</span>
								<span class="phase-free_article_tag">イベント・学会発表</span>
							</div>
							<p class="phase-free_article_text">要検討内容です。この文章が45文字です。</p>
						</div>
					</a>
				</article>
				<article class="phase-free_article">
					<a href="#" class="phase-free_article_link">
						<figure class="phase-free_article_fig">
							<img src={IMG_PATH + 'top/dummy.webp'} alt="" loading="lazy">
						</figure>
						<div class="phase-free_article_content">
							<div class="phase-free_article_meta">
								<span class="phase-free_article_cat" data-type="prepare">備える</span>
								<span class="phase-free_article_tag">準備・対策</span>
							</div>
							<p class="phase-free_article_text">45文字が最大文字数（仮）。3行に入り切る文字数。要検討内容です。この文章が45文字です。</p>
						</div>
					</a>
				</article>
				<article class="phase-free_article">
					<a href="#" class="phase-free_article_link">
						<figure class="phase-free_article_fig">
							<img src={IMG_PATH + 'top/dummy.webp'} alt="" loading="lazy">
						</figure>
						<div class="phase-free_article_content">
							<div class="phase-free_article_meta">
								<span class="phase-free_article_cat" data-type="prepare">備える</span>
								<span class="phase-free_article_tag">イベント・学会発表</span>
							</div>
							<p class="phase-free_article_text">45文字が最大文字数（仮）。3行に入り切る文字数。要検討内容です。この文章が45文字です。</p>
						</div>
					</a>
				</article>
				<article class="phase-free_article">
					<a href="#" class="phase-free_article_link">
						<figure class="phase-free_article_fig">
							<img src={IMG_PATH + 'top/dummy.webp'} alt="" loading="lazy">
						</figure>
						<div class="phase-free_article_content">
							<div class="phase-free_article_meta">
								<span class="phase-free_article_cat" data-type="prepare">備える</span>
								<span class="phase-free_article_tag">イベント・学会発表</span>
							</div>
							<p class="phase-free_article_text">45文字が最大文字数（仮）。3行に入り切る文字数。要検討内容です。この文章が45文字です。</p>
						</div>
					</a>
				</article>
			</div>
		</Inner>
	</div>

	<div class="joint">
		<Inner addClass="joint_inner">
			<div class="joint_titlebox">
				<h2 class="joint_title">JOINT RESEARCH</h2>
				<a href="#" class="joint_btn">共同研究 <img src={IMG_PATH + 'common/arrow.svg'} alt="共同研究"></a>
			</div>
		</Inner>
		<div class="joint_slider swiper js-joint-swiper">
			<ul class="joint_list swiper-wrapper">
				<li class="joint_item swiper-slide">
					<a href="#" class="joint_link">
						<div class="joint_img">
							<img src={IMG_PATH + 'top/joint_01_off.webp'} alt="避難状況の予測に関する研究 Yu Hiroi" class="joint_img_off" loading="lazy">
							<img src={IMG_PATH + 'top/joint_01_on.webp'} alt="" class="joint_img_on" loading="lazy">
						</div>
					</a>
				</li>
				<li class="joint_item swiper-slide">
					<a href="#" class="joint_link">
						<div class="joint_img">
							<img src={IMG_PATH + 'top/joint_02_off.webp'} alt="災害対策業務のあり方に関する研究 Numada Muneyoshi" class="joint_img_off" loading="lazy">
							<img src={IMG_PATH + 'top/joint_02_on.webp'} alt="" class="joint_img_on" loading="lazy">
						</div>
					</a>
				</li>
				<li class="joint_item swiper-slide">
					<a href="#" class="joint_link">
						<div class="joint_img">
							<img src={IMG_PATH + 'top/joint_03_off.webp'} alt="地域福祉のあり方に関する研究 Sugano Taku" class="joint_img_off" loading="lazy">
							<img src={IMG_PATH + 'top/joint_03_on.webp'} alt="" class="joint_img_on" loading="lazy">
						</div>
					</a>
				</li>
			</ul>
			<div class="swiper-button-prev joint_prev"></div>
			<div class="swiper-button-next joint_next"></div>
		</div>
	</div>

	<div class="news">
		<Inner>
			<div class="news_header">
				<h2 class="news_title">NEWS RELEASE</h2>
				<a href="#" class="news_more">一覧を見る <img src={IMG_PATH + 'common/arrow.svg'} alt="一覧を見る"></a>
			</div>
			<ul class="news_list">
				<li class="news_item">
					<a href="#" class="news_link">
						<span class="news_date">2026.4.1</span>
						<p class="news_text">ダミーです。過去の事象からの研究結果を発表しました。</p>
						<span class="news_arrow">
							<svg xmlns="http://www.w3.org/2000/svg" width="6" height="10" viewBox="0 0 6 10" aria-hidden="true">
								<path d="M1 1l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</span>
					</a>
				</li>
				<li class="news_item">
					<a href="#" class="news_link">
						<span class="news_date">2026.4.1</span>
						<p class="news_text">ダミーです。過去の事象からの研究結果を発表しました。</p>
						<span class="news_arrow">
							<svg xmlns="http://www.w3.org/2000/svg" width="6" height="10" viewBox="0 0 6 10" aria-hidden="true">
								<path d="M1 1l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</span>
					</a>
				</li>
				<li class="news_item">
					<a href="#" class="news_link">
						<span class="news_date">2026.4.1</span>
						<p class="news_text">ダミーです。過去の事象からの研究結果を発表しました。</p>
						<span class="news_arrow">
							<svg xmlns="http://www.w3.org/2000/svg" width="6" height="10" viewBox="0 0 6 10" aria-hidden="true">
								<path d="M1 1l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</span>
					</a>
				</li>
			</ul>
		</Inner>
	</div>

	<div class="contact">
		<Inner addClass="contact_inner">
			<h2 class="contact_title">CONTACT</h2>
			<p class="contact_subtitle">私たちとできること</p>
			<p class="contact_desc">
				防災研は次なる地域防災の構築へ。<br class="contact_desc_br">
				より多くのステークホルダーの皆さまと知見を共有し、<br class="contact_desc_br">
				広めていきたいと考えています。<br class="contact_desc_br">
				防災研の取り組みに関するご意見、ご質問、ご要望等については、<br class="contact_desc_br">
				ご遠慮なく、ぜひ一度お問い合わせください。
			</p>
			<ul class="contact_list">
				<li class="contact_item">
					<a href="#" class="contact_box">
						<span class="contact_box_tl"></span>
						<span class="contact_box_tr"></span>
						<span class="contact_box_bl"></span>
						<span class="contact_box_br"></span>
						<p class="contact_box_text">地域・自治体<br>の皆さまへ</p>
					</a>
				</li>
				<li class="contact_item">
					<a href="#" class="contact_box">
						<span class="contact_box_tl"></span>
						<span class="contact_box_tr"></span>
						<span class="contact_box_bl"></span>
						<span class="contact_box_br"></span>
						<p class="contact_box_text">企業・大学・研究機関<br>の皆さまへ</p>
					</a>
				</li>
				<li class="contact_item">
					<a href="#" class="contact_box">
						<span class="contact_box_tl"></span>
						<span class="contact_box_tr"></span>
						<span class="contact_box_bl"></span>
						<span class="contact_box_br"></span>
						<p class="contact_box_text">メディア<br>の皆さまへ</p>
					</a>
				</li>
			</ul>
		</Inner>
	</div>
</Layout>

<script>
import Swiper from 'swiper';
import { Navigation } from 'swiper/modules';
import 'swiper/css';
import 'swiper/css/navigation';

new Swiper('.js-joint-swiper', {
	modules: [Navigation],
	loop: true,
	navigation: {
		nextEl: '.joint_next',
		prevEl: '.joint_prev',
	},
	breakpoints: {
		0: {
			slidesPerView: 1.5,
			centeredSlides: true,
			spaceBetween: 20,
		},
		768: {
			slidesPerView: 3,
			spaceBetween: 20,
			centeredSlides: false,
			allowTouchMove: false,
		}
	}
});
</script>

<style lang="scss">

.about {
	position: relative;
	padding: 110px 0;
	text-align: center;
	color: g.color('white');
	overflow: hidden;

	@include g.mq('md') {
		padding: 100px 0;
	}

	&_video {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		z-index: -1;

		&_pc {
			display: none;
			@include g.mq('md') {
				display: block;
			}
		}

		&_sp {
			display: block;
			@include g.mq('md') {
				display: none;
			}
		}
	}

	&_inner {
		position: relative;
		z-index: 1;
	}

	&_content {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	&_title {
		font-family: g.font('en');
		font-size: 4.5rem;
		line-height: 1.25;
		margin-bottom: 5px;
		letter-spacing: 0.05em;
		font-weight: 500;
		opacity: 0.5;

		@include g.mq('md') {
			font-size: 10rem;
			margin-bottom: 10px;
		}
	}

	&_subtitle {
		font-size: 2.0rem;
		font-weight: 700;
		margin-bottom: 30px;
		letter-spacing: 0.05em;

		@include g.mq('md') {
			font-size: 2.4rem;
			margin-bottom: 20px;
		}
	}

	&_text {
		font-size: 1.6rem;
		line-height: 2;
		margin-bottom: 30px;
		letter-spacing: 0.05em;
		text-align: center;

		@include g.mq('md') {
			font-size: 1.6rem;
			line-height: 1.75;
			margin-bottom: 60px;
		}
	}

	&_btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		color: g.color('white');
		font-family: g.font('en');
		font-size: 1.4rem;
		font-weight: 700;
		text-decoration: none;
		letter-spacing: 0.05em;
		transition: opacity 0.3s ease;

		@include g.mq('md') {
			font-size: 1.6rem;
		}

		img{
			position: relative;
			top: 1px;
			rotate: -90deg;
			filter: brightness(0) invert(1);
		}
	}
}

.phase-free {
	padding: 87px 0;
	background: g.color('bg');

	@include g.mq('md') {
		padding: 117px 0;
	}

	&_header {
		text-align: center;
		margin-bottom: 20px;

		@include g.mq('md') {
			margin-bottom: 40px;
		}
	}

	&_title {
		font-size: 2.0rem;
		font-weight: 700;
		color: #333;

		@include g.mq('md') {
			font-size: 2.4rem;
		}
	}

	&_actions {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 20px;
		margin-bottom: 57px;
		width: 89%;
		margin-inline: auto;
		
		@include g.mq('md') {
			width: 100%;
			grid-template-columns: repeat(4, 1fr);
			gap: 4px;
			margin-bottom: 65px;
		}
	}

	&_action {
		display: flex;
		justify-content: center;
		align-items: center;
		text-decoration: none;
		color: g.color('white');
		padding: 5px 5px 10px;
		min-height: 78px;
		transition: opacity 0.3s ease;

		@include g.mq('md') {
			min-height: 90px;
			padding: 10px 5px 20px;

			&:hover {
				opacity: 0.8;
			}
		}

		&--communicate {
			background-color: #1a56a4;
		}

		&--prepare {
			background-color: #278ceb;
		}

		&--act {
			background-color: #00bed7;
		}

		&--connect {
			background-color: #00ac96;
		}

		&_inner {
			display: flex;
			flex-direction: column;
			align-items: center;
			text-align: center;
			position: relative;
			padding: 0 5px;
			width: 100%;
			height: 100%;

			@include g.mq('md') {
				padding: 0 10px;
			}
		}

		&_main {
			font-size: 2.0rem;
			font-weight: 700;
			margin-bottom: 2px;
			letter-spacing: 0.1em;

			@include g.mq('md') {
				font-size: 2.6rem;
				margin-bottom: 5px;
			}
		}

		&_sub {
			display: flex;
			align-items: center;
			justify-content: center;
			min-width: 90px;
			min-height: 32px;
			font-size: 1.2rem;
			line-height: 1.4;
			position: relative;
			padding: 0 10px;

			@include g.mq('md') {
				font-size: 1.4rem;
				padding: 0 12px;
			}

			&::before,
			&::after {
				content: '';
				position: absolute;
				top: 50%;
				transform: translateY(-50%);
				width: 1px;
				height: 80%;
				background-color: rgba(255, 255, 255, 0.5);

				@include g.mq('md') {
					height: 100%;
				}
			}

			&::before {
				left: 0;
			}

			&::after {
				right: 0;
			}
		}
	}

	&_articles {
		display: grid;
		grid-template-columns: 1fr;
		gap: 60px;

		@include g.mq('md') {
			grid-template-columns: repeat(3, 1fr);
			gap: 64px 50px;
		}
	}

	&_article {
		&_link {
			display: flex;
			flex-direction: column;
			text-decoration: none;
			color: g.color('base');
			transition: opacity 0.3s ease;
			height: 100%;

			@include g.mq('md') {
				&:hover {
					opacity: 0.7;
				}
			}
		}

		&_fig {
			position: relative;
			margin: 0 0 15px 0;
			overflow: hidden;
			background-color: #7e7e7e;
			height: 234px;
			
			@include g.mq('md') {
				margin: 0 0 20px 0;
				height: 210px;
			}

			img {
				height: 100%;
				width: auto;
				object-fit: cover;
				display: block;
				transition: transform 0.3s ease;
				margin-inline: auto;
			}
		}

		@include g.mq('md') {
			&:hover &_fig img {
				transform: scale(1.1);
			}
		}

		&_content {
			flex-grow: 1;
			padding-bottom: 30px;
			border-bottom: 1px solid #333333;
			
			@include g.mq('md') {
				padding-bottom: 40px;
			}
		}

		&_meta {
			display: flex;
			align-items: center;
			flex-wrap: wrap;
			gap: 8px;
			margin-bottom: 15px;
			font-size: 1.2rem;
			
			@include g.mq('md') {
				margin-bottom: 20px;
				font-size: 1.4rem;
			}
		}

		&_cat {
			position: relative;
			padding-left: 40px;

			&::before {
				content: '';
				position: absolute;
				top: 50%;
				left: 0;
				transform: translateY(-50%);
				width: 30px;
				height: 10px;
			}

			&[data-type="communicate"] {
				&::before {
					background-color: #1a56a4;
				}
			}

			&[data-type="prepare"] {
				&::before {
					background-color: #278ceb;
				}
			}

			&[data-type="act"] {
				&::before {
					background-color: #00bed7;
				}
			}

			&[data-type="connect"] {
				&::before {
					background-color: #00ac96;
				}
			}
		}

		&_tag {
			position: relative;
			padding-left: 10px;

			&::before {
				content: '|';
				position: absolute;
				left: 0;
				color: #ccc;
			}
		}

		&_text {
			font-size: 1.6rem;
			line-height: 1.6;
			font-weight: 500;
			color: #333;
			display: -webkit-box;
			-webkit-line-clamp: 3;
			-webkit-box-orient: vertical;
			overflow: hidden;

			@include g.mq('md') {
				font-size: 1.8rem;
			}
		}
	}
}

.joint {
	padding: 60px 0;
	position: relative;
	background: g.color('bg');
	overflow: hidden;

	&_titlebox {
		display: flex;
		flex-direction: column;
		align-items: center;
		margin-bottom: 30px;

		@include g.mq('md') {
			flex-direction: row;
			justify-content: space-between;
			align-items: flex-end;
			margin-bottom: 40px;
		}
	}

	&_title {
		font-family: g.font('en');
		font-size: 3.2rem;
		line-height: 1.2;
		background: linear-gradient(90deg, g.color('key'), g.color('key_light'));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		margin-bottom: 15px;

		@include g.mq('md') {
			font-size: 5.6rem;
			margin-bottom: 0;
		}
	}

	&_btn {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: g.color('key');
		font-weight: 700;
		text-decoration: none;
		font-size: 1.4rem;

		img {
			width: 1em;
		}

		@include g.mq('md') {
			font-size: 1.6rem;
		}
	}

