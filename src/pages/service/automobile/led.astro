---
/********************************************************************
 * 	TOP
 **********************************************************************/
 import { BASE_DIR, IMG_PATH } from '/src/consts';
import Layout from '@layouts/Layout.astro';
import Inner from '@components/Inner.astro';
import SidebarArea from '@components/SidebarArea.astro';
import MvLower from '@components/MvLower.astro';
import TitleH1 from '@components/TitleH1.astro';
import MvCategory from '@components/MvCategory.astro';

const meta = {
	title: 'LED素子',
	description: '',
}
---
<Layout pageId="documents" title={meta.title} description={meta.description}>
    <MvLower title="分析対象" subTitle="Analytic subjects" src="mv/mv-service.webp" />
    <TitleH1 title="LED素子" />
    <div class="main">
        <Inner>
            <SidebarArea parent="分析対象" parent2="自動車" parent3="LED素子"/>
            <div id="content">
                <div class="print-btn"><a href="#" onclick="window.print();return false;"><img src={IMG_PATH + "common/btn_print.svg"} alt="このページを印刷する" width="189" height="33"></a></div>
                <MvCategory 
                    imageSrc={IMG_PATH + "/service/led_01.webp"}
                    alt="LED素子"
                    lead="LEDはEVの高効率化に欠かせないデバイスですが、微小欠陥の影響や樹脂材料の劣化など、“見えない要因”が性能・歩留まりに直結します。<br>弊社は素子内部の微細構造から樹脂材料の信頼性まで、ミクロ解析で課題の原因を特定し、LED開発・製造の改善を支援します。<br>材料と構造をワンストップで評価し、高性能化・長寿命化への確かな解決策をご提供します。"
                />
                <h2 id="item-analysis" class="h2-service">分析項目</h2>
                <table class="tbl-service-doc">
                    <tbody><tr>
                      <th class="th-service-doc-section" scope="col">分析項目</th>
                      <th class="th-service-doc-analyzer" scope="col">使用機器・手法</th>
                      <th class="th-service-doc-doc-title300" scope="col">分析事例</th>
                    </tr>
                    <tr>
                      <td>表面組成・化学状態</td>
                      <td>XPS</td>
                      <td>&nbsp;</td>
                    </tr>
                    <tr>
                      <td>多層構造</td>
                      <td>AES、<a href="../../documents/s0701_510.html">TOF-SIMS</a></td>
                      <td>&nbsp;</td>
                    </tr>
                    <tr>
                      <td>断面層構造</td>
                      <td><a href="../../documents/m1602_550.html">TEM</a>、<a href="../../documents/s0501_520.html">SEM</a></td>
                      <td><a href="../../documents/s334_114.html">発光ダイオードの断面観察</a></td>
                    </tr>
                    <tr>
                      <td>断面の結晶構造</td>
                      <td><a href="../../documents/m1602_550.html">電子線回折TEM-ED</a></td>
                      <td><a href="../../documents/s397_114.html">TEMによるGaN中転移構造の詳細観察</a></td>
                    </tr>
                    <tr>
                      <td rowspan="3">欠陥解析</td>
                      <td rowspan="3"><a href="../../documents/m1602_550.html">TEM</a>、<a href="../../documents/s0501_520.html">SEM</a></td>
                      <td><a href="../../documents/s382_114.html">ヘテロ接合界面に生成した微小ドメインの解析</a></td>
                    </tr>
                    <tr>
                      <td><a href="../../documents/s470_114.html">半導体ヘテロ接合界面のTEMひずみ解析</a></td>
                    </tr>
                    <tr>
                      <td><a href="../../documents/s281_114.html">EELSマッピング</a></td>
                    </tr>
                    <tr>
                      <td>樹脂材料</td>
                      <td>総合分析</td>
                      <td>熱、光による高分子の劣化分析</td>
                    </tr>
                    </tbody>
                </table>
            </div>
        </Inner>
    </div>
</Layout>

<style lang="scss">
@use "@styles/lower.scss";
</style>

<script>
	import '@scripts/rowspanBottomLine.js';
</script>