---
/********************************************************************
 * 	TOP
 **********************************************************************/
 import { BASE_DIR, IMG_PATH } from '/src/consts';
import Layout from '@layouts/Layout.astro';
import Inner from '@components/Inner.astro';
import SidebarArea from '@components/SidebarArea.astro';
import MvLower from '@components/MvLower.astro';
import TitleH1 from '@components/TitleH1.astro';
import MvCategory from '@components/MvCategory.astro';
import Contents from '@components/Contents.astro';

const meta = {
	title: '食品・健康食品',
	description: '',
}

const contentsList = [
    { num: 1, txt: '食品・健康食品に関する分野の分析項目', href: '#health-food' },
    { num: 2, txt: '機能性食品、特定保健用食品（特保＝トクホ）の分析', href: '#functional-food' },
];
---
<Layout pageId="documents" title={meta.title} description={meta.description}>
    <MvLower title="分析対象" subTitle="Analytic subjects" src="mv/mv-service.webp" />
    <TitleH1 title="食品・健康食品" />
    <div class="main">
        <Inner>
            <SidebarArea parent="分析対象" parent2="ライフサイエンス" parent3="食品・健康食品"/>
            <div id="content">
                <div class="print-btn"><a href="#" onclick="window.print();return false;"><img src={IMG_PATH + "common/btn_print.svg"} alt="このページを印刷する" width="189" height="33"></a></div>
                <MvCategory 
                    imageSrc={IMG_PATH + "/service/food_01.webp"}
                    alt="食品・健康食品"
                    lead="近年、食の安全性が注目を集めていますが、弊社では、食品の主成分、不純物/微量重金属、異物分析、包装容器の分析など、広い分野の分析で経験を有しています。"
                />
